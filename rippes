entity:SetCallback("OnDamagePlayer", function(newHealth)
    if newHealth <= 0 then
        if ReSt:FindFirstChild("GameStats") then
            local stats = ReSt.GameStats:FindFirstChild("Player_"..Plr.Name)
            if stats then
                stats.Total.DeathCause.Value = "Ripper"
            end
        end

        local character = Plr.Character
        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
            character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
            if character:FindFirstChild("HumanoidRootPart") then
                character.HumanoidRootPart.Anchored = true
            end
        end

        CustomGitSound("https://github.com/Kotyara19k-Doorsspawner/Random-files/raw/main/Y2meta.app%20-%20Doors%20HardCore%20Mode_%201%20ripper%20part%20sound%20(320%20kbps).mp3", 1, "Ripper5Sound")
        task.wait(1.5)

        CustomGitSound("https://github.com/Kotyara19k-Doorsspawner/Random-files/raw/main/Y2meta.app%20-%20Doors%20Hardcore%20Mode_%20Ripperscare%20part%202%20sound%20(320%20kbps).mp3", 1, "Ripper6Sound")
        
        local playerGui = Plr:FindFirstChild("PlayerGui")
        if playerGui and playerGui:FindFirstChild("MainUI") and playerGui.MainUI:FindFirstChild("Drip") then
            local drip = playerGui.MainUI.Drip
            drip.Image = "rbxassetid://236542974"
            drip.Visible = true; task.wait(0.3)
            drip.Visible = false; task.wait(0.1)
            drip.Visible = true; task.wait(0.2)
            drip.Visible = false; task.wait(0.3)
            drip.Visible = true; task.wait(0.2)
            drip.Visible = false; task.wait(0.2)
        end

        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid.Health = 0
        end

        local gameStats = ReSt:FindFirstChild("GameStats")
        if gameStats and gameStats:FindFirstChild("Player_"..Plr.Name) then
            gameStats["Player_"..Plr.Name].Total.DeathCause.Value = "Ripper"
        end

        -- Custom Executor Hooks for Death Hints
        local func
        local getgc = getgc or (getfenv and getfenv().getgc)
        if getgc and getinfo and setupval then
            for _, v in next, getgc(false) do
                if typeof(v) == "function" then
                    local info = getinfo(v)
                    if info and info.currentline == 54 and info.nups == 2 and info.is_vararg == 0 then
                        func = v
                        break
                    end
                end
            end
            
            if func then
                setupval(func, 1, {"You died who you call Ripper...", "You can tell his presence by the lights and his scream.", "Hide when does this!"})
                setupval(func, 2, "Guiding")
            end
        end
    end
end)

