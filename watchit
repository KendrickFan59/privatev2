local spawner = loadstring(game:HttpGet("https://raw.githubusercontent.com/RegularVynixu/Utilities/main/Doors/Entity%20Spawner/V2/Source.lua"))()

game.Lighting.MainColorCorrection.TintColor = Color3.fromRGB(0, 80, 255)
game.Lighting.MainColorCorrection.Contrast = 1

local TweenService = game:GetService("TweenService")
TweenService:Create(game.Lighting.MainColorCorrection,TweenInfo.new(2.5),{Contrast = 0}):Play()

local TW = TweenService:Create(game.Lighting.MainColorCorrection,TweenInfo.new(80),{TintColor = Color3.fromRGB(255,255,255)})
TW:Play()

local spawnCount = 0
local maxSpawn = 5

local function SpawnEntity()
	if spawnCount >= maxSpawn then return end
	spawnCount += 1

	local entity = spawner.Create({
		Entity = {
			Name = "Rebound",
			Asset = "https://github.com/KendrickFan59/privatev2/raw/refs/heads/main/fires.rbxm",
			HeightOffset = 0
		},
		Lights = {
			Flicker = {
				Enabled = true,
				Duration = 1
			},
			Shatter = true,
			Repair = false
		},
		CameraShake = {
			Enabled = false
		},
		Movement = {
			Speed = 100,
			Delay = 1,
			Reversed = true
		},
		Rebounding = {
			Enabled = false
		},
		Damage = {
			Enabled = true,
			Range = 40,
			Amount = 9999
		},
		Crucifixion = {
			Enabled = false
		},
		Death = {
			Type = "Guiding",
			Hints = {"you die to rebound"},
			Cause = "die to rebound"
		}
	})

	entity:SetCallback("OnLookAt", function()
		local ReSt = game.ReplicatedStorage
		local Plr = game.Players.LocalPlayer
		ReSt.GameStats["Player_"..Plr.Name].Total.DeathCause.Value = "die to rebound"
	end)

	entity:Run()
end

SpawnEntity()

local LatestRoom = workspace.CurrentRooms:WaitForChild(game.ReplicatedStorage.GameData.LatestRoom.Value)

workspace.CurrentRooms.ChildAdded:Connect(function(room)
	if spawnCount < maxSpawn then
		task.wait(1)
		SpawnEntity()
	end
end)
